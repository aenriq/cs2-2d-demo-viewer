{
  "name": "cs2-demo-viewer",
  "version": "0.1.0",
  "description": "Unstyled React hooks and components for CS2 2D demo replay from parsed JSON",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "cs2",
    "counter-strike",
    "demo",
    "replay",
    "react",
    "radar",
    "2d"
  ],
  "files": [
    "dist",
    "assets",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "vite --config dev/vite.config.ts",
    "build": "tsup",
    "build:dev": "vite build --config dev/vite.config.ts",
    "fetch-icons": "bun run scripts/fetch-killfeed-icons.ts",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@pixi/react": "^8.0.0",
    "pixi.js": "^8.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@pixi/react": "^8.0.5",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "pixi.js": "^8.14.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  },
  "engines": {
    "node": ">=18"
  }
}
